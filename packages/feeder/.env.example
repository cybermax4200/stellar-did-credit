# ---------------------------------------------------------------------------
# Required — feeder will not start without these
# ---------------------------------------------------------------------------

# Stellar secret key of the feeder account (S...).
# Must be registered on-chain first: register_feeder(admin, FEEDER_PUBLIC_KEY)
FEEDER_SECRET=YOUR_STELLAR_SECRET_KEY

# Comma-separated list of subject G... addresses to sync each cycle
SUBJECTS=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX,GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# credit-oracle contract address (C...)
CREDIT_ORACLE_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# identity-oracle contract address (C...)
IDENTITY_ORACLE_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ---------------------------------------------------------------------------
# Optional — defaults shown are for Stellar testnet
# ---------------------------------------------------------------------------

# Network passphrase
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Soroban RPC endpoint
RPC_URL=https://soroban-testnet.stellar.org

# Horizon REST API endpoint
HORIZON_URL=https://horizon-testnet.stellar.org

# Any funded account used as fee source for read-only contract simulations
SIM_ACCOUNT=GAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAWHF

# How often to run a full feed cycle, in milliseconds (default: 1 hour)
POLL_INTERVAL_MS=3600000
