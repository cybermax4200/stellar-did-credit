{
  "name": "stellar-did-credit",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "prepare": "lefthook install",
    "lint": "eslint packages --ext .ts && cargo clippy --workspace -- -D warnings",
    "lint:fix": "eslint packages --ext .ts --fix && cargo clippy --fix --allow-dirty --workspace -- -D warnings",
    "test": "cargo test --workspace && pnpm --filter './packages/*' --if-present test",
    "build": "pnpm --filter './packages/*' --if-present build && cargo build --workspace"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "lefthook": "1.11.13"
  }
}
